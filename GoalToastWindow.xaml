<Window x:Class="FlashscoreOverlay.GoalToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Goal Alert" Height="100" Width="400" 
        WindowStyle="None" ResizeMode="NoResize" 
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        MouseLeftButtonUp="Window_MouseLeftButtonUp" Cursor="Hand">

    <!-- CSS Replica -->
    <!-- .fs-c { display: flex; height: 100%; } -->
    <!-- .fs-n-v8-opt { background: #1f1f1f; color: #fff; font-family... border-radius: 4px; border: 1px solid #333; } -->
    
    <Border Background="#1f1f1f" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" 
            Margin="0,0,10,10" >
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="10" ShadowDepth="3" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- fs-l Panel Izquierdo -->
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="1" />
                <!-- fs-r Panel Derecho -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- fs-l: Left panel -->
            <Border Background="#2b2b2b" Grid.Column="0" CornerRadius="4,0,0,4">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5">
                    <Image x:Name="PlayerImage" Height="40" Stretch="Uniform" Margin="0,0,0,2"/>
                    <TextBlock x:Name="PlayerNameText" Foreground="White" FontSize="13" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="130" />
                    <TextBlock x:Name="TeamNameText" Foreground="#aaaaaa" FontSize="10" TextAlignment="Center" Margin="0,2,0,0" TextWrapping="Wrap" MaxWidth="130" />
                    <TextBlock Text="GOL" Foreground="#FF0046" FontSize="14" FontWeight="Black" TextAlignment="Center" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            
            <!-- Separator -->
            <Border Background="#444444" Grid.Column="1" />

            <!-- fs-r: Right panel -->
            <Grid Grid.Column="2" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Home Team -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image x:Name="HomeLogo" Width="30" Height="30" Stretch="Uniform" Margin="0,0,0,5"/>
                    <TextBlock x:Name="HomeTeamName" Foreground="White" FontSize="11" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Score / Time Box -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="HomeScore" Foreground="White" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text=" - " Foreground="White" FontSize="20" FontWeight="Bold" Margin="2,0,2,0" />
                        <!-- Assuming the goal was from away, maybe highlight the scoring team? Simplified here -->
                        <TextBlock x:Name="AwayScore" Foreground="#FF0046" FontSize="20" FontWeight="Bold" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock x:Name="MinuteText" Foreground="#FF0046" FontSize="15" FontWeight="Bold" />
                            <TextBlock Text="'" Foreground="#FF0046" FontSize="15" FontWeight="Bold">
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1.0" To="0.0" Duration="0:0:1" 
                                                                 AutoReverse="True" RepeatBehavior="Forever" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Away Team -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image x:Name="AwayLogo" Width="30" Height="30" Stretch="Uniform" Margin="0,0,0,5"/>
                    <TextBlock x:Name="AwayTeamName" Foreground="White" FontSize="11" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>
